# Bazel configuration for react-native-macos
# Reference: https://bazel.build/reference/command-line-reference

# Performance
build --jobs=auto
query --jobs=auto

# Common compiler flags
build --cxxopt='-std=c++17'
build --objcopt='-fblocks'

# macOS / iOS specific settings
build:macos --platforms=@local_config_platform//:host
build:ios --platforms=//:ios_target

# Stricter build environment
build --incompatible_strict_action_env

# Enable dynamic linking for faster local development
build:dev --dynamic_mode=off

# CI mode: more aggressive optimization
build:ci --jobs=1
build:ci --verbose_failures

# Remote cache configuration (can be overridden via bazelrc.user or environment)
# Future: integrate with GitHub Actions cache
# build --remote_cache=https://...

# Common exclusions to speed up build
common --noenable_bzlmod

# Python compatibility (for code generators and build tools)
build --python_version=PY3
